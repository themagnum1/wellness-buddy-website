{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/about",       "destination": "/about.html" },
    { "source": "/solutions",   "destination": "/solutions.html" },
    { "source": "/thrive-desk", "destination": "/thrive-desk.html" },
    { "source": "/shop",        "destination": "/shop.html" },
    { "source": "/partners",    "destination": "/partners.html" },
    { "source": "/podcast",     "destination": "/podcast.html" },
    { "source": "/contact",     "destination": "/contact.html" }
  ]
}
